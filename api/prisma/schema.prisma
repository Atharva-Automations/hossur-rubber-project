generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// InwardEntry  — main batch-level record
// ─────────────────────────────────────────────
model InwardEntry {
  id             Int             @id @default(autoincrement())
  materialName   String
  supplierName   String
  quantity       Float
  unit           String          
  bagWeight      Float?
  storedAsWhole  Boolean          @default(false)
  mfgDate        DateTime
  expDate        DateTime
  status         String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  qrCodes        InwardQrCode[]
}


// ─────────────────────────────────────────────
// InwardQrCode  — one record per bag
// ─────────────────────────────────────────────
model InwardQrCode {
  id         Int       @id @default(autoincrement())
  bagNo      Int
  label      String
  qrId       String
  inwardId   Int
  inward     InwardEntry @relation(fields: [inwardId], references: [id], onDelete: Cascade)
  printed    Boolean     @default(false)
  createdAt  DateTime    @default(now())
}

// ─────────────────────────────────────────────
// Outward Entries — issuing materials for production
// ─────────────────────────────────────────────
model OutwardEntry {
  id             Int       @id @default(autoincrement())
  materialName   String
  quantity       Float
  unit           String    @default("KG")

  bagsIssued     Int?                // no. of bags issued
  status         String    @default("Pending") // Pending → Completed
  qrScanStatus   Json?               // track each bag: scanned / not-scanned

  date           DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// Material Stock — live quantity summary
// ─────────────────────────────────────────────
model MaterialStock {
  id             Int      @id @default(autoincrement())
  materialName   String   @unique
  totalQuantity  Float
  unit           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
