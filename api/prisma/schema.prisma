// @ts-ignore – Prisma type doesn't expose relation ordering, but it works at runtime
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QrState {
  CREATED // 1 – printed & in inventory (after inward)
  ISSUED // 2 – scanned for outward, leaving inventory
  CONSUMED // 3 – scanned at production/bin
}

enum IngredientType {
  BASE_POLYMER
  FILLER
  ACTIVATOR
  ACCELERATOR
  CURING_AGENT
  PROCESSING_AID
  PIGMENT
  OTHER
}

enum StepType {
  KNEADER
  MIXING
}

enum BatchStatus {
  CREATED
  WEIGHING
  EXECUTING
  COMPLETED
}

enum ProductExecutionStatus {
  CREATED
  WEIGHING_IN_PROGRESS
  WEIGHING_COMPLETED
  STEP_IN_PROGRESS
  STEP_COMPLETED
  PRODUCT_COMPLETED
}

enum StepExecutionStatus {
  PENDING
  READY
  IN_PROGRESS
  DONE
}

enum BagStatus {
  CREATED
  SCANNED
  CONSUMED
}

enum BulkSeedStatus {
  CREATED // generated, not used yet
  SCANNED // QR scanned at weighing station
  WEIGHED // weight confirmed, WeighedBag row created
}

// ─────────────────────────────────────────────
// InwardEntry  — main batch-level record
// ─────────────────────────────────────────────
model InwardEntry {
  id            Int            @id @default(autoincrement())
  materialName  String
  supplierName  String
  quantity      Float
  unit          String
  bagWeight     Float?
  storedAsWhole Boolean        @default(false)
  mfgDate       DateTime
  expDate       DateTime
  status        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  qrCodes       InwardQrCode[]
}

// ─────────────────────────────────────────────
// InwardQrCode  — one record per bag
// ─────────────────────────────────────────────
// add this field to your existing model
model InwardQrCode {
  id    Int    @id @default(autoincrement())
  qrId  String @unique
  bagNo Int
  label String

  inwardId Int
  inward   InwardEntry @relation(fields: [inwardId], references: [id], onDelete: Cascade)

  state               QrState   @default(CREATED)
  outwardId           Int?
  printed             Boolean   @default(false)
  scannedAtOutward    DateTime?
  scannedAtProduction DateTime?
  consumedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Optional: quick lookup index (not required—tag already unique)
  // @@index([tag])
}

// ─────────────────────────────────────────────
// Outward Entries — issuing materials for production
// ─────────────────────────────────────────────
model OutwardEntry {
  id           Int    @id @default(autoincrement())
  materialName String
  quantity     Float
  unit         String @default("KG")

  issuedTo String
  purpose  String?
  remarks  String?

  qrScanStatus Json?
  status       String @default("Pending")

  bagsIssued Int?

  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Material Stock — live quantity summary
// ─────────────────────────────────────────────
model MaterialStock {
  id            Int      @id @default(autoincrement())
  materialName  String   @unique
  totalQuantity Float
  unit          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Ingredient — defines a material-ingredient link
// ─────────────────────────────────────────────
model Ingredient {
  id              Int               @id @default(autoincrement())
  ingredientCode  String            @unique
  name            String?
  type            IngredientType
  materialName    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  bins            BinAssignment[]
  recipeLinks     StepIngredient[]
  BatchIngredient BatchIngredient[]
}

// ─────────────────────────────────────────────
// Bin Assignment — maps ingredient to a bin
// ─────────────────────────────────────────────
model BinAssignment {
  id              Int        @id @default(autoincrement())
  binNumber       String     @unique
  ingredientId    Int        @unique
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  minQuantity     Float
  maxQuantity     Float
  currentQuantity Float      @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// ─────────────────────────────────────────────
// Recipe creation - recipe details
// ─────────────────────────────────────────────
model Recipe {
  id          Int      @id @default(autoincrement())
  recipeCode  String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps RecipeStep[]
  Batch Batch[]
}

// ─────────────────────────────────────────────
// Recipe steps details - each step details
// ─────────────────────────────────────────────
model RecipeStep {
  id       Int    @id @default(autoincrement())
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  stepType       StepType
  sequenceNumber Int
  timerSeconds   Int
  pressure       Float
  temperature    Float
  rpm            Float

  ingredients StepIngredient[]
  batchSteps  BatchStep[]

  @@index([recipeId])
}

// ─────────────────────────────────────────────
// Ingredient details - maps ingredient to each step
// ─────────────────────────────────────────────
model StepIngredient {
  id     Int        @id @default(autoincrement())
  stepId Int
  step   RecipeStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  quantity Float
  unit     String
}

// ─────────────────────────────────────────────
// Batch — main production batch record linking recipe, steps, and execution
// ─────────────────────────────────────────────
model Batch {
  id       Int         @id @default(autoincrement())
  recipeId Int
  quantity Int
  status   BatchStatus @default(CREATED)

  // Track which steps will be executed in this batch
  executeKneader Boolean @default(true)
  executeMixer   Boolean @default(true)

  // Weighing strategy: ONE_BY_ONE (sequential) or BULK (all at once)
  // This affects both QR printing and ingredient weighing process
  // ONE_BY_ONE: Print 1 QR → weigh 1 ingredient → move to next
  // BULK: Print all QRs first → then weigh ingredients in any order
  weighingStrategy String @default("ONE_BY_ONE") // ONE_BY_ONE or BULK

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  recipe            Recipe             @relation(fields: [recipeId], references: [id])
  steps             BatchStep[]
  weighedBags       WeighedBag[]
  executionScans    ExecutionScan[]
  finalProducts     FinalProduct[]
  productExecutions ProductExecution[]
  bulkSeeds         BulkWeighingSeed[]
  finalBatch        FinalBatch?
}

// ─────────────────────────────────────────────
// BatchStep — execution step within a batch
// ─────────────────────────────────────────────
model BatchStep {
  id             Int                 @id @default(autoincrement())
  batchId        Int
  recipeStepId   Int? // Link back to original recipe step for audit
  stepType       StepType // KNEADER or MIXING (Ref from Recipe DTO enum)
  sequenceNumber Int
  timerSeconds   Int
  pressure       Float
  temperature    Float
  rpm            Float
  status         StepExecutionStatus @default(PENDING)

  startedAt   DateTime?
  completedAt DateTime?

  batch          Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  recipeStep     RecipeStep?        @relation(fields: [recipeStepId], references: [id])
  ingredients    BatchIngredient[]
  weighedBags    WeighedBag[]
  executionScans ExecutionScan[]
  stepExecutions StepExecution[]
  bulkSeeds      BulkWeighingSeed[]

  @@index([batchId])
  @@index([recipeStepId])
}

// ─────────────────────────────────────────────
// BatchIngredient — links ingredients to batch steps with quantities
// ─────────────────────────────────────────────
model BatchIngredient {
  id              Int    @id @default(autoincrement())
  batchStepId     Int
  ingredientId    Int
  quantityPerUnit Float // Per single product unit
  totalQuantity   Float // Total for all units in batch
  unit            String
  sequenceInStep  Int    @default(1) // Order in which this ingredient appears in the step

  batchStep      BatchStep          @relation(fields: [batchStepId], references: [id], onDelete: Cascade)
  ingredient     Ingredient         @relation(fields: [ingredientId], references: [id])
  weighedBags    WeighedBag[]
  executionScans ExecutionScan[]
  bulkSeeds      BulkWeighingSeed[]

  @@unique([batchStepId, sequenceInStep])
  @@index([batchStepId])
  @@index([ingredientId])
}

// ─────────────────────────────────────────────
// WeighedBag — individual bags weighed during production batch steps
// Each bag gets a NEW INDEPENDENT QR (not related to inward QR)
// ─────────────────────────────────────────────
model WeighedBag {
  id                 Int       @id @default(autoincrement())
  qrId               String    @unique
  batchId            Int
  productExecutionId Int // Which product (1 of 10, 2 of 10, etc.)
  batchStepId        Int
  batchIngredientId  Int
  weight             Float
  status             BagStatus @default(CREATED)

  scannedForVerification DateTime? // When was this bag scanned before adding to bin/mixer
  addedToBinAt           DateTime? // When was this bag actually added to bin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch            Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productExecution ProductExecution @relation(fields: [productExecutionId], references: [id], onDelete: Cascade)
  batchStep        BatchStep        @relation(fields: [batchStepId], references: [id], onDelete: Cascade)
  batchIngredient  BatchIngredient  @relation(fields: [batchIngredientId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([productExecutionId])
  @@index([batchStepId])
  @@index([batchIngredientId])
}

  @@index([batchId])
  @@index([productExecutionId])
  @@index([batchStepId])
  @@index([batchIngredientId])
}

// ─────────────────────────────────────────────
// BulkWeighingSeed - this stores the bulk qrs generated before weighing
// ─────────────────────────────────────────────
model BulkWeighingSeed {
  id   Int    @id @default(autoincrement())
  qrId String @unique

  batchId            Int
  productExecutionId Int
  batchStepId        Int
  batchIngredientId  Int

  status    BulkSeedStatus @default(CREATED)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  batch            Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productExecution ProductExecution @relation(fields: [productExecutionId], references: [id], onDelete: Cascade)
  batchStep        BatchStep        @relation(fields: [batchStepId], references: [id], onDelete: Cascade)
  batchIngredient  BatchIngredient  @relation(fields: [batchIngredientId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([productExecutionId])
  @@index([batchStepId])
  @@index([batchIngredientId])
}

// ─────────────────────────────────────────────
// ExecutionScan — tracks QR code scans during batch step execution
// ─────────────────────────────────────────────
model ExecutionScan {
  id                 Int      @id @default(autoincrement())
  qrId               String
  batchId            Int
  productExecutionId Int
  batchStepId        Int
  batchIngredientId  Int // Which ingredient being added
  sequenceInStep     Int // Order of ingredient in this step
  scannedAt          DateTime @default(now())

  batch            Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productExecution ProductExecution @relation(fields: [productExecutionId], references: [id], onDelete: Cascade)
  batchStep        BatchStep        @relation(fields: [batchStepId], references: [id], onDelete: Cascade)
  batchIngredient  BatchIngredient  @relation(fields: [batchIngredientId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([productExecutionId])
  @@index([batchStepId])
}

// ─────────────────────────────────────────────
// ProductExecution — tracks a single product's execution within a batch
// ─────────────────────────────────────────────
model ProductExecution {
  id              Int                    @id @default(autoincrement())
  batchId         Int
  productSequence Int // Which product in batch (1, 2, 3... 10)
  status          ProductExecutionStatus @default(CREATED)

  weighingStartedAt    DateTime?
  weighingCompletedAt  DateTime?
  executionStartedAt   DateTime?
  executionCompletedAt DateTime?

  batch          Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  weighedBags    WeighedBag[]
  executionScans ExecutionScan[]
  stepExecutions StepExecution[]
  finalProduct   FinalProduct[]
  bulkSeeds      BulkWeighingSeed[]

  @@unique([batchId, productSequence])
  @@index([batchId])
}

// ─────────────────────────────────────────────
// StepExecution — tracks execution of each step for each product
// ─────────────────────────────────────────────
model StepExecution {
  id                 Int @id @default(autoincrement())
  productExecutionId Int
  batchStepId        Int

  status      StepExecutionStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?

  // Track all ingredients added in this step for this product
  ingredientsAdded    Int @default(0)
  ingredientsExpected Int

  productExecution ProductExecution @relation(fields: [productExecutionId], references: [id], onDelete: Cascade)
  batchStep        BatchStep        @relation(fields: [batchStepId], references: [id], onDelete: Cascade)

  @@unique([productExecutionId, batchStepId])
  @@index([productExecutionId])
  @@index([batchStepId])
}

// ─────────────────────────────────────────────
// FinalProduct — finished goods after batch completion
// ─────────────────────────────────────────────
model FinalProduct {
  id                 Int      @id @default(autoincrement())
  batchId            Int
  productExecutionId Int
  productSequence    Int // Which product in batch (1, 2, 3... 10)
  qrId               String   @unique
  binId              String? // If applicable, which bin it was completed in
  completedAt        DateTime @default(now())
  createdAt          DateTime @default(now())

  batch            Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productExecution ProductExecution @relation(fields: [productExecutionId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([productExecutionId])
}

//
//
//
model FinalBatch {
  id        Int      @id @default(autoincrement())
  batchId   Int      @unique
  qrId      String
  createdAt DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id])
}
