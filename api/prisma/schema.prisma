generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QrState {
  CREATED      // 1 – printed & in inventory (after inward)
  ISSUED       // 2 – scanned for outward, leaving inventory
  CONSUMED     // 3 – scanned at production/bin
}

// ─────────────────────────────────────────────
// InwardEntry  — main batch-level record
// ─────────────────────────────────────────────
model InwardEntry {
  id             Int             @id @default(autoincrement())
  materialName   String
  supplierName   String
  quantity       Float
  unit           String          
  bagWeight      Float?
  storedAsWhole  Boolean          @default(false)
  mfgDate        DateTime
  expDate        DateTime
  status         String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  qrCodes        InwardQrCode[]
}


// ─────────────────────────────────────────────
// InwardQrCode  — one record per bag
// ─────────────────────────────────────────────
model InwardQrCode {
  id         Int       @id @default(autoincrement())
  qrId       String      @unique
  bagNo      Int
  label      String

  inwardId   Int
  inward     InwardEntry @relation(fields: [inwardId], references: [id], onDelete: Cascade)

  state      QrState   @default(CREATED)
  outwardId  Int?      
  printed    Boolean   @default(false)
  scannedAtOutward DateTime?
  scannedAtProduction DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
}

// ─────────────────────────────────────────────
// Outward Entries — issuing materials for production
// ─────────────────────────────────────────────
model OutwardEntry {
  id             Int       @id @default(autoincrement())
  materialName   String
  quantity       Float
  unit           String     @default("KG")

  issuedTo       String
  purpose        String?
  remarks        String?

  qrScanStatus   Json?
  status         String     @default("Pending")

  bagsIssued     Int?

  date           DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ─────────────────────────────────────────────
// Material Stock — live quantity summary
// ─────────────────────────────────────────────
model MaterialStock {
  id             Int      @id @default(autoincrement())
  materialName   String   @unique
  totalQuantity  Float
  unit           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
